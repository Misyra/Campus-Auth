direction: down

classes: {
  start: { shape: oval; style.fill: "#e3f2fd"; style.stroke: "#1976d2" }
  process: { shape: rectangle; style.fill: "#fff"; style.stroke: "#424242" }
  decision: { shape: diamond; style.fill: "#fff3e0"; style.stroke: "#f57c00" }
  ok: { shape: rectangle; style.fill: "#e8f5e9"; style.stroke: "#388e3c" }
  fail: { shape: rectangle; style.fill: "#ffebee"; style.stroke: "#c62828" }
}

# ── 启动 ──
start: "启动监控" { class: start }
init: "初始化\nmonitoring=true\nretry_count=0" { class: process }

# ── 主循环 ──
loop: "主循环\nwhile monitoring" { class: ok }

# ── 暂停检查 ──
is-pause: "暂停时段？" { class: decision }
wait-pause: "等待配置间隔" { class: process }

# ── 网络检测 ──
check-net: "网络检测\nTCP + HTTP + Portal" { class: process }
net-ok: "网络正常？" { class: decision }

# ── 网络正常 ──
net-good: "重置计数器\n等待下次检测 (interval)" { class: ok }

# ── 网络异常 → 登录恢复 ──
net-bad: "网络异常" { class: fail }
check-local: "物理网络连接？" { class: decision }
local-fail: "物理断开\n等待下次检测" { class: fail }
check-auth: "认证地址可达？" { class: decision }
auth-fail: "地址不可达\n等待下次检测" { class: fail }

# ── 重试检查 ──
retry-exceed: "超过重试次数？" { class: decision }
give-up: "放弃\n等待下次检测" { class: fail }

# ── 执行登录 ──
do-login: "执行登录\n→ 登录流程图" { class: process }
login-ok: "登录成功？" { class: decision }

# ── 登录结果 ──
login-success: "登录成功\n重置计数器" { class: ok }
login-fail: "登录失败\nretry_count++" { class: fail }
retry-wait: "等待重试\n5s → 30s → 60s" { class: process }

# ── 周期结束（统一回到循环）──
end-cycle: "本轮结束\n重置/等待" { class: ok }

# ── 流程 ──
start -> init -> loop

loop -> is-pause
is-pause -> wait-pause: "是"
wait-pause -> end-cycle

is-pause -> check-net: "否"
check-net -> net-ok
net-ok -> net-good: "是"
net-good -> end-cycle

net-ok -> net-bad: "否"
net-bad -> check-local

check-local -> local-fail: "否"
local-fail -> end-cycle

check-local -> check-auth: "是"
check-auth -> auth-fail: "否"
auth-fail -> end-cycle

check-auth -> retry-exceed: "是"
retry-exceed -> give-up: "是"
give-up -> end-cycle

retry-exceed -> do-login: "否"
do-login -> login-ok

login-ok -> login-success: "是"
login-success -> end-cycle

login-ok -> login-fail: "否"
login-fail -> retry-wait
retry-wait -> check-local: "重试"

end-cycle -> loop
