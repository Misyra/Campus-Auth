# 校园网自动认证工具配置模板
# 复制此文件为 .env 并填写实际值

# 注意：以下配置项已迁移到 settings.json（通过 Web 控制台管理）：
#   LOGIN_URL, ISP, BROWSER_HEADLESS, BROWSER_TIMEOUT, BROWSER_USER_AGENT,
#   BROWSER_LOW_RESOURCE_MODE, MONITOR_INTERVAL, AUTO_START_MONITORING,
#   PING_TARGETS, PAUSE_LOGIN_ENABLED, PAUSE_LOGIN_START_HOUR, PAUSE_LOGIN_END_HOUR,
#   BROWSER_DISABLE_WEB_SECURITY, BROWSER_EXTRA_HEADERS_JSON, CUSTOM_VARIABLES
# 这些配置现在以"配置方案"形式存储在 settings.json 中，支持多网络环境切换。
# 本文件仅保留敏感数据和系统级配置。

# ============= 基础认证配置（全局共享） =============
# 校园网用户名（必填）
USERNAME=your_username_here

# 校园网密码（必填）
PASSWORD=your_password_here

# ============= 系统配置 =============
# Web 控制台端口（1-65535）
APP_PORT=50721

# HTTP请求日志（true=在控制台显示API请求，false=隐藏）
UVICORN_ACCESS_LOG=false

# ============= Playwright 自动安装配置 =============
# 首次启动时自动安装 playwright 包 + Chromium（建议保持 true）
AUTO_INSTALL_PLAYWRIGHT=true

# Playwright 浏览器下载镜像（可按需替换）
PLAYWRIGHT_DOWNLOAD_HOST=https://npmmirror.com/mirrors/playwright

# ============= 重试策略配置 =============
# 最大重试次数
RETRY_MAX_RETRIES=3

# 重试间隔（秒）
RETRY_INTERVAL=5

# ============= 日志配置 =============
# 日志级别（DEBUG, INFO, WARNING, ERROR）
LOG_LEVEL=WARNING

# 后端日志级别（未设置时使用 LOG_LEVEL）
BACKEND_LOG_LEVEL=WARNING

# 前端日志级别
FRONTEND_LOG_LEVEL=WARNING

# 日志格式
LOG_FORMAT=%(asctime)s - %(levelname)s - %(message)s

# 日志文件路径（留空则不写入文件）
LOG_FILE=logs/campus_auth.log

# 系统托盘配置
MINIMIZE_TO_TRAY=true

# ============= 安全提醒 =============
# 1. 请确保 .env 文件权限设置为 600（仅所有者可读写）
# 2. 不要将包含真实密码的 .env 文件提交到版本控制系统
# 3. 定期更改密码以保护账户安全
# 4. 如需分享配置，请使用此 .env.example 模板文件

# ============= 使用说明 =============
# 1. 复制此文件：cp .env.example .env
# 2. 编辑 .env 文件并填写真实的用户名和密码
# 3. 根据需要调整其他配置项
