# Campus-Auth 启动配置
# 仅包含需要在应用启动前生效的变量
# 业务配置（账号密码、日志、浏览器等）已迁移到 settings.json

# Web 控制台端口（1-65535）
APP_PORT=50721

# API 鉴权 Token（留空则不启用鉴权）
API_TOKEN=

# Playwright 自动安装（首次启动时自动安装 Chromium）
AUTO_INSTALL_PLAYWRIGHT=true

# Playwright 浏览器下载镜像
PLAYWRIGHT_DOWNLOAD_HOST=https://npmmirror.com/mirrors/playwright
