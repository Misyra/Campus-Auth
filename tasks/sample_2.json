{
  "name": "样例2",
  "description": "案例2：通过明确选择器执行账号、密码、运营商和登录按钮步骤（不能直接使用，请自行修改）",
  "version": "3.3.0",
  "source": "builtin",
  "url": "{{LOGIN_URL}}",
  "timeout": 30000,
  "steps": [
    {
      "id": "navigate",
      "type": "navigate",
      "description": "打开认证页面",
      "timeout": 10000,
      "url": "{{url}}",
      "wait_until": "domcontentloaded"
    },
    {
      "id": "input_username",
      "type": "input",
      "description": "输入账号（元素识别）",
      "timeout": 5000,
      "selector": "input[name='DDDDD'], input[name='username'], #username, input[placeholder*='账号'], input[placeholder*='用户名']",
      "value": "{{username}}"
    },
    {
      "id": "input_password",
      "type": "input",
      "description": "输入密码（元素识别）",
      "timeout": 5000,
      "selector": "input[name='upass'], input[name='password'], input[type='password'], #password",
      "value": "{{password}}"
    },
    {
      "id": "select_isp",
      "type": "select",
      "description": "选择运营商下拉（无值或未检测到自动跳过）",
      "timeout": 3000,
      "selector": "select[name='ISP_select'], select[name='isp'], #isp, select[id*='运营商'], select[name*='carrier']",
      "value": "{{isp}}"
    },
    {
      "id": "click_login",
      "type": "click",
      "description": "点击登录",
      "timeout": 5000,
      "selector": "input[name='0MKKey'], input[type='submit'], button[type='submit'], #login, .login-btn"
    },
    {
      "id": "wait_result",
      "type": "sleep",
      "description": "等待登录结果",
      "duration": 3000
    },
    {
      "id": "eval_result",
      "type": "eval",
      "description": "判断登录是否成功",
      "script": "(() => { const text = String((document.body && document.body.innerText) || '') + ' ' + String(document.title || ''); const okWords = ['登录成功', '认证成功', '已连接', '已上线', '欢迎', 'success', 'connected']; const badWords = ['失败', '错误', '无效', '密码错误', '账号错误', 'failed', 'error']; const has = (arr) => arr.some((w) => text.toLowerCase().includes(w.toLowerCase())); if (has(badWords)) return false; return has(okWords); })()",
      "store_as": "login_success"
    }
  ],
  "success_conditions": [
    {
      "type": "variable",
      "variable": "login_success",
      "value": true
    }
  ],
  "variables": {
    "username": "{{USERNAME}}",
    "password": "{{PASSWORD}}",
    "isp": "{{ISP}}"
  },
  "on_success": {
    "message": "案例2执行完成（元素识别）",
    "screenshot": false
  },
  "on_failure": {
    "message": "案例2执行失败（元素识别）",
    "screenshot": true
  },
  "id": "sample_2"
}