{
  "name": "城市热点认证",
  "description": "城市热点(Dr.COM)校园网认证流程",
  "version": "1.0",
  "author": "Community",
  "url": "http://172.29.0.2",
  "variables": {
    "username": "{{CAMPUS_USERNAME}}",
    "password": "{{CAMPUS_PASSWORD}}"
  },
  "timeout": 30000,
  "steps": [
    {
      "id": "navigate",
      "type": "navigate",
      "url": "{{url}}",
      "description": "打开认证页面",
      "wait_until": "networkidle"
    },
    {
      "id": "input_username",
      "type": "input",
      "selector": "#DDDDD, input[name='DDDDD']",
      "value": "{{username}}",
      "clear": true,
      "description": "输入用户名"
    },
    {
      "id": "input_password",
      "type": "input",
      "selector": "#upass, input[name='upass']",
      "value": "{{password}}",
      "clear": true,
      "description": "输入密码"
    },
    {
      "id": "click_login",
      "type": "click",
      "selector": "#button_0, input[type='submit'], button[type='submit']",
      "description": "点击登录按钮"
    },
    {
      "id": "wait_redirect",
      "type": "wait_url",
      "pattern": "success|portal|index",
      "timeout": 10000,
      "description": "等待页面跳转"
    }
  ],
  "on_success": {
    "message": "城市热点认证成功"
  },
  "on_failure": {
    "message": "城市热点认证失败",
    "screenshot": true
  }
}
