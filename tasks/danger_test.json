{
  "name": "危险步骤测试",
  "description": "用于测试安全确认弹窗的任务，包含 eval 和 custom_js 步骤",
  "version": "1.0.0",
  "source": "api",
  "url": "http://172.29.0.2",
  "timeout": 30000,
  "steps": [
    {
      "id": "navigate",
      "type": "navigate",
      "url": "{{url}}",
      "description": "打开认证页面"
    },
    {
      "id": "wait_load",
      "type": "wait",
      "selector": "#username",
      "timeout": 5000,
      "description": "等待页面加载"
    },
    {
      "id": "inject_creds",
      "type": "custom_js",
      "description": "通过JS注入账号密码",
      "script": "document.querySelector('#username').value = '{{username}}';\ndocument.querySelector('#password').value = '{{password}}';\nconsole.log('凭据已注入');"
    },
    {
      "id": "get_token",
      "type": "eval",
      "description": "动态获取表单token",
      "script": "return document.querySelector('input[name=\"token\"]')?.value || '';"
    },
    {
      "id": "click_login",
      "type": "custom_js",
      "description": "模拟点击登录按钮",
      "script": "const btn = document.querySelector('#login-btn');\nif (btn) {\n  btn.disabled = false;\n  btn.click();\n}"
    },
    {
      "id": "check_result",
      "type": "eval",
      "description": "判断登录是否成功",
      "script": "return document.body.innerText.includes('成功') || document.body.innerText.includes('success');"
    }
  ],
  "success_conditions": [
    {
      "type": "eval",
      "condition": "document.body.innerText.includes('成功')"
    }
  ]
}
