{
  "reveal_hidden": true,
  "navigation_wait": 5,
  "name": "校园网登录",
  "description": "适用于 10.8.2.2 ePortal 认证页面（无线认证）",
  "metadata": {
    "author": "task-generator",
    "device": "无线接入点",
    "created": "2026-06-23"
  },
  "url": "{{LOGIN_URL}}",
  "timeout": 30000,
  "step_delay": 0.5,
  "variables": {
    "username": "{{USERNAME}}",
    "password": "{{PASSWORD}}",
    "isp": "{{ISP}}"
  },
  "steps": [
    {
      "id": "s1",
      "type": "input",
      "description": "输入账号",
      "selector": "#username, input[name='username']",
      "value": "{{username}}",
      "clear": true,
      "timeout": 10000
    },
    {
      "id": "s2",
      "type": "input",
      "description": "输入密码",
      "selector": "#pwd, input[name='pwd']",
      "value": "{{password}}",
      "clear": true,
      "timeout": 10000
    },
    {
      "id": "s3",
      "type": "click_select",
      "description": "选择运营商",
      "selector": "#xiala",
      "value": "{{isp}}",
      "option_selector": "[id^='_service_']",
      "timeout": 10000
    },
    {
      "id": "s4",
      "type": "click",
      "description": "点击登录按钮",
      "selector": "#loginLink_div",
      "timeout": 10000
    },
    {
      "id": "s5",
      "type": "wait_url",
      "description": "等待认证结果跳转",
      "pattern": "success|welcome|error|fail",
      "timeout": 15000
    }
  ],
  "on_success": {
    "message": "登录成功"
  },
  "on_failure": {
    "message": "登录失败",
    "screenshot": true
  }
}
