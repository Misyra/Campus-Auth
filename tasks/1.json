{
  "id": "1",
  "name": "知乎2",
  "description": "1",
  "version": "1.0",
  "url": "https://www.zhihu.com/signin?next=%2F",
  "variables": {
    "username": "{{CAMPUS_USERNAME}}",
    "password": "{{CAMPUS_PASSWORD}}"
  },
  "timeout": 30000,
  "steps": [
    {
      "type": "navigate",
      "url": "{{url}}",
      "wait_until": "domcontentloaded",
      "description": "打开知乎登录页"
    },
    {
      "type": "click",
      "selector": "div.SignFlow-tab[role='button']",
      "description": "点击密码登录标签"
    },
    {
      "type": "wait",
      "selector": "input[name='username'].Input",
      "timeout": 5000,
      "description": "等待用户名输入框加载完成"
    },
    {
      "type": "input",
      "selector": "input[name='username'].Input",
      "value": "{{username}}",
      "clear": true,
      "description": "输入手机号/邮箱账号"
    },
    {
      "type": "input",
      "selector": "input[name='password'].Input",
      "value": "{{password}}",
      "clear": true,
      "description": "输入登录密码"
    },
    {
      "type": "click",
      "selector": "button.Button.SignFlow-submitButton",
      "description": "点击登录按钮"
    }
  ],
  "success_conditions": [
    {
      "type": "url_contains",
      "pattern": "success|home|dashboard",
      "description": "登录成功后URL包含指定关键词"
    }
  ],
  "on_success": {
    "message": "登录成功！"
  },
  "on_failure": {
    "message": "登录失败，请检查账号密码或页面元素是否匹配",
    "screenshot": true
  }
}